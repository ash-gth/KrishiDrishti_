# KrishiDrishti - Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=KrishiDrishti
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# ── Database ─────────────────────────────────────────────────────────────────
# Replace with your actual PostgreSQL credentials
DATABASE_URL=postgresql://postgres:password@localhost:5432/krishidrishti

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── File Upload ───────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# ── ML Model ─────────────────────────────────────────────────────────────────
MODEL_PATH=models/plant_disease_model.h5
CONFIDENCE_THRESHOLD=0.5

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-a-random-256-bit-key

# ── Redis (optional) ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=false
